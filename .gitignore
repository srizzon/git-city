# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# private docs (strategy, plans, content scripts)
GROWTH_PLAN.md
docs/plans/
docs/tiktok/
docs/cloudflare-setup.md

# claude code local settings
.claude/

trace/
docs/

*.mp4
*.mov

.vscode

# partykit local state
.partykit/

# Local-only dev / asset-pipeline scripts (not needed to run or fork the app).
# NOTE: scripts/bake-sf-map.mjs (regenerates public/maps/sf.json) and
# scripts/upload-arcade-assets.mjs (seeds the arcade-assets bucket, per CLAUDE.md)
# are intentionally NOT ignored — forkers need them.
scripts/test-*.mjs
scripts/recolor-*.mjs
scripts/crop-walk-sprites.mjs
scripts/gen-seed.mjs
scripts/restore-from-backup.mjs
scripts/seed-landmarks.mjs
scripts/extract-cozy-furniture.py
scripts/x-thread.txt
# Bankr sponsor-vehicle GLB pipeline (output is gitignored under public/models/vehicles/)
scripts/bankr-model.mjs
scripts/gen-bankr-monitor.mjs
scripts/render-preview.mjs
public/bankr.svg
public/bankr-monitor-preview.html

# local POCs / scratch SQL / supabase CLI cache
poc/
supabase/snippets/
supabase/.temp/

# vscode extension build artifacts
packages/vscode-extension/dist/
packages/vscode-extension/package-lock.json
packages/vscode-extension/*.vsix

public/cozy/

# Cosmetic GLB models live in Supabase Storage (bucket cosmetic-models), not git.
# A new cosmetic is upload + a catalog row — never a commit. Generated locally as
# upload staging via scripts/gen-*.mjs, then pushed with upload-cosmetic-models.mjs.
public/models/vehicles/

# Production schema dumps used for local bootstrapping (never commit prod artifacts)
supabase/*.prod_schema.sql

# OSM raw cache for SF map bake (re-downloadable)
scripts/.osm-cache/

# Raw Kenney asset-kit downloads. We commit only the GLBs we use (public/models);
# the unpacked kit folders stay local.
kenney/
